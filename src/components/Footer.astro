---
import { Icon } from "astro-icon/components";
import { LINKS, INFO, SOCIALS } from "@/consts.ts";
---

<footer class="flex flex-col gap-8 max-w-prose mx-auto my-20 px-6">
  <section class="flex flex-col sm:flex-row divide-x-0 divide-y sm:divide-x sm:divide-y-0 divide-light/50">
    <div class="flex flex-col gap-4 pb-8 sm:py-0 sm:pr-6">
      <a href="/" class="text-3xl font-serif flex gap-2 items-center group">
        Enzo Glow
        <Icon name="ri:arrow-right-double-line" class="opacity-0 -translate-x-full group-hover:translate-x-0 group-hover:opacity-100 text-sage transition-all linear duration-200"/>
      </a>
      <a href={INFO.PHONE_HREF} class="flex gap-2 items-center group">
        {INFO.PHONE}
        <Icon name="ri:external-link-line" class="opacity-0 -translate-x-full group-hover:translate-x-0 group-hover:opacity-100 text-sage transition-all linear duration-200"/>
      </a>
      <a href={INFO.EMAIL_HREF} class="flex gap-2 items-center group">
        {INFO.EMAIL}
        <Icon name="ri:external-link-line" class="opacity-0 -translate-x-full group-hover:translate-x-0 group-hover:opacity-100 text-sage transition-all linear duration-200"/>
      </a>
      <div class="flex gap-4">
        {
          SOCIALS.map((social) => (
            <a href={social.HREF} class="flex gap-2 items-center">
              <Icon name={social.ICON} class="w-6 h-6" />
            </a>
          ))
        }
      </div>
    </div>
    <nav class="grid grid-rows-3 grid-flow-col gap-4 sm:flex sm:flex-col sm:gap-4 pt-8 sm:pt-0 sm:pl-8">
      {
        LINKS.map((link) => (
          <a href={link.HREF} class="flex gap-2 items-center group">
            {link.TEXT}
            <Icon name="ri:arrow-right-double-line" class="opacity-0 -translate-x-full group-hover:translate-x-0 group-hover:opacity-100 text-sage transition-all linear duration-200"/>
          </a>
        ))
      }
    </nav>
  </section>
  <section class="flex flex-col items-center gap-2">
    <a href="/cancellation-policy" class="text-sm flex items-center group gap-2">
      Cancellation Policy
      <Icon name="ri:arrow-right-double-line" class="opacity-0 -translate-x-full group-hover:translate-x-0 group-hover:opacity-100 text-sage transition-all linear duration-200"/>
    </a>
    <p class="text-sm">Copyright &copy; 2024 Enzo Glow. All rights reserved.</p>
  </section>
</footer>
