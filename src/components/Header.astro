---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import { INFO, LINKS, SOCIALS } from "@/consts.ts";
---

<header id="mynav" class="min-h-20 p-6 fixed w-full transition-all ease-in-out duration-300s z-20">
  <nav
    x-data="{ mobileMenuIsOpen: false }"
    @click.away="mobileMenuIsOpen = false"
    class="flex items-center justify-between"
    aria-label="navigation menu"
  >
    <!-- Brand Logo -->
    <a href="/" class="text-3xl font-serif">
      Enzo Glow
    </a>
    <!-- Desktop Menu -->
    <ul class="tracking-widest hidden items-center gap-4 md:flex uppercase">
      {
        LINKS.map((link) => (
          <li>
            <a href={link.HREF} class="">
              {link.TEXT}
            </a>
          </li>
        ))
      }
    </ul>
    <!-- Mobile Menu Button -->
    <button
      @click="mobileMenuIsOpen = !mobileMenuIsOpen"
      :aria-expanded="mobileMenuIsOpen"
      :class="mobileMenuIsOpen ? 'fixed top-6 right-6 z-50' : null"
      type="button"
      class="flex text-light hover:text-sage md:hidden"
      aria-label="mobile menu"
      aria-controls="mobileMenu"
    >
      <Icon
        x-cloak
        x-show="!mobileMenuIsOpen"
        aria-hidden="true"
        name="ri:menu-line"
        class="w-10 h-10"
      />
      <Icon
        x-cloak
        x-show="mobileMenuIsOpen"
        aria-hidden="true"
        name="ri:close-line"
        class="w-10 h-10"
      />
    </button>
    <!-- Mobile Menu -->
    <div
      x-cloak
      x-show="mobileMenuIsOpen"
      x-transition:enter="transition motion-reduce:transition-none ease-in-out duration-300"
      x-transition:enter-start="-translate-y-full"
      x-transition:enter-end="translate-y-0"
      x-transition:leave="transition motion-reduce:transition-none ease-in-out duration-300"
      x-transition:leave-start="translate-y-0"
      x-transition:leave-end="-translate-y-full"
      id="mobileMenu"
      class="fixed overflow-y-auto max-h-svh inset-x-0 border-b border-light/20 top-0 z-40 pt-20 pb-6 px-6 bg-night md:hidden"
    >
      <ul class="flex flex-col mb-6">
        {
          LINKS.map((link) => (
            <li class="py-2">
              <a href={link.HREF} class="text-xl group flex items-center gap-2 tracking-widest uppercase">
                {link.TEXT}
                <Icon name="ri:arrow-right-double-line" class="opacity-0 -translate-x-full group-hover:translate-x-0 group-hover:opacity-100 text-sage transition-all linear duration-200"/>
              </a>
            </li>
          ))
        }
      </ul>
      <div class="flex flex-col gap-2">
        <a href={INFO.PHONE_HREF} class="flex gap-2 items-center group">
          {INFO.PHONE}
          <Icon name="ri:external-link-line" class="opacity-0 -translate-x-full group-hover:translate-x-0 group-hover:opacity-100 text-sage transition-all linear duration-200"/>
        </a>
        <a href={INFO.EMAIL_HREF} class="flex gap-2 items-center group">
          {INFO.EMAIL}
          <Icon name="ri:external-link-line" class="opacity-0 -translate-x-full group-hover:translate-x-0 group-hover:opacity-100 text-sage transition-all linear duration-200"/>
        </a>
      </div>
      <div class="flex gap-4 my-6">
        {
          SOCIALS.map((social) => (
            <a href={social.HREF} class="flex gap-2 items-center">
              <Icon name={social.ICON} class="w-6 h-6"/>
            </a>
          ))
        }
      </div>
    </div>
  </nav>
  <!-- <div class="flex gap-4 items-center">
    <button
      id="header-theme-button"
      class="hidden sm:block h-6 w-6 hover:text-pink-500"
    >
      <Icon name="ri:sun-fill" class="block dark:hidden size-full" />
      <Icon name="ri:moon-clear-fill" class="hidden dark:block size-full" />
    </button>
  </div> -->
</header>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    window.addEventListener('scroll', function() {
      if (window.scrollY > 10) {
        document.getElementById('mynav')?.classList.add('bg-night');
        // document.getElementById('mynav')?.classList.add('backdrop-blur');
        // document.getElementById('mynav')?.classList.add('bg-gradient-to-b');
        // document.getElementById('mynav')?.classList.add('from-neutral-900');
        // document.getElementById('mynav')?.classList.add('to-transparent');
      } else {
        document.getElementById('mynav')?.classList.remove('bg-night');
        // document.getElementById('mynav')?.classList.remove('backdrop-blur');
        // document.getElementById('mynav')?.classList.remove('bg-gradient-to-b');
        // document.getElementById('mynav')?.classList.remove('from-neutral-900');
        // document.getElementById('mynav')?.classList.remove('to-transparent');
      }
    });
  });
</script>