---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { INFO } from "@/consts.ts";

import redReliefFacialImg from "@/assets/services/red-relief-facial.jpg";

const pageTitle = "Contact";
---

<BaseLayout pageTitle={pageTitle}>
  <section class="mt-20 mx-auto">
    <!-- <h1 class="max-w-prose mx-auto mb-6">{pageTitle}</h1> -->
    <!-- <p>Interested in Enzo Glow's </p> -->
    <!-- <p class="font-serif text-4xl p-4">Interested in Enzo Glow's services?</p> -->
    <!-- <p class="font-serif text-4xl p-4">We&apos;d love to hear from you!</p> -->
    <div class="relative h-80 w-full ">
      <Image src={redReliefFacialImg} alt="facials" class="h-full w-full object-cover" />
      <div class="absolute inset-0 h-full w-full bg-black opacity-60">
      </div>
      <div class="absolute inset-0 h-full w-full flex flex-col justify-center items-center">
        <p class="font-serif text-4xl p-4">Call or email to book today!</p>
        <div class="flex flex-col gap-4">
          <a href={INFO.PHONE_HREF} class="group flex justify-center items-center gap-2 font-light tracking-widest h-16 w-80 uppercase border border-light p-4 backdrop-blur hover:bg-light/20 hover:text-light transition-all ease-in-out duration-300">
            {INFO.PHONE}
            <!-- <Icon name="ri:external-link-line" class="opacity-0 -translate-x-full group-hover:translate-x-0 group-hover:opacity-100 text-light transition-all linear duration-200"/> -->
          </a>
          <a href={INFO.EMAIL_HREF} class="group flex justify-center items-center gap-2 font-light tracking-widest h-16 w-80 uppercase border border-light p-4 backdrop-blur hover:bg-light/20 hover:text-light transition-all ease-in-out duration-300">
            {INFO.EMAIL}
            <!-- <Icon name="ri:external-link-line" class="opacity-0 -translate-x-full group-hover:translate-x-0 group-hover:opacity-100 text-light transition-all linear duration-200"/> -->
          </a>
        </div>
      </div>
    </div>
    <div class="px-6">
      <p class="max-w-prose mx-auto mt-6">Please reach out with any questions about our services or concerns about your skin care.</p>
      <p class="max-w-prose mx-auto mt-6">
        Please review our
        <a href="/cancellation-policy" class="underline">Cancellation Policy.</a>
      </p>
    </div>
    <!-- <Icon name="ri:phone-fill" />
    <p>{INFO.PHONE}</p>
    <Icon name="ri:mail-line" />
    <p>{INFO.EMAIL}</p> -->
  </section>
</BaseLayout>
